# Stripe server secret. Set this in Vercel environment variables, never in client code.
STRIPE_SECRET_KEY=sk_test_xxx

# Optional: use a Stripe Dashboard Price ID for easier price changes without redeploying.
STRIPE_FULL_REPORT_PRICE_ID=

# Used only when STRIPE_FULL_REPORT_PRICE_ID is empty.
STRIPE_REPORT_PRICE_AMOUNT=990
STRIPE_REPORT_PRICE_CURRENCY=cny
STRIPE_REPORT_PRODUCT_NAME=性压抑指数完整报告

# Public display label shown on the result page.
PUBLIC_SRI_REPORT_PRICE_LABEL=￥9.9

# Production site URL used for Stripe success/cancel redirects.
PUBLIC_SITE_URL=https://your-domain.example
